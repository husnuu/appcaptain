# Database — Supabase poolers (Settings > Database > Connection string)
# Transaction pooler (app/runtime on Vercel — port 6543, NOT 5432)
# Add connection_limit=1 for serverless to avoid exhausting the pool (limit ~200).
DATABASE_URL="postgresql://postgres.<project-ref>:<DB-PASSWORD>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Session pooler / direct (Prisma migrations only — never use as DATABASE_URL on Vercel)
DIRECT_URL="postgresql://postgres.<project-ref>:<DB-PASSWORD>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# API
API_PORT=4000
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
# Comma-separated browser origins allowed by CORS. Both CAPTAIN_ORIGIN and
# ADMIN_ORIGIN are merged into the allow-list (see apps/api/src/app.ts).
# Local: http://localhost:3002 (captain), http://localhost:3001 (admin)
# Production (Vercel): set these to the deployed captain/admin domains.
CAPTAIN_ORIGIN="http://localhost:3002"
# Admin panel origin(s). Production example:
#   https://appcaptain-admin.vercel.app
ADMIN_ORIGIN="http://localhost:3001"

# Supabase
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_JWT_SECRET=""            # Project Settings > API > JWT Secret (verifies access tokens)
SUPABASE_PHOTOS_BUCKET="boat-photos"
SUPABASE_DOCUMENTS_BUCKET="boat-documents"
SUPABASE_EXPERIENCE_PHOTOS_BUCKET="experience-photos"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Apps
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Mapbox (Captain konum haritası — https://account.mapbox.com/access-tokens/)
NEXT_PUBLIC_MAPBOX_TOKEN="pk.your-mapbox-public-token"

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"

# Seed (optional override for the requirements JSON path)
# ONBOARDING_SEED_FILE="/absolute/path/to/seahub_boat_listing_requirements_seed.json"
