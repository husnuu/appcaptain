{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "cd ../.. && corepack enable && corepack prepare pnpm@9.15.0 --activate && pnpm install --filter @getyourboat/api...",
  "buildCommand": "pnpm build:vercel",
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "includeFiles": "{../../node_modules/.prisma/**,../../node_modules/@prisma/client/**,../../packages/database/generated/**}"
    }
  }
}
